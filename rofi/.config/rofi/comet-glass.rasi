/**
 * comet-glass.rasi
 * Dreamy indigo/cyan Rofi theme for Hyprland
 */

configuration {
    modi: "drun,run,window";
    show-icons: true;
    icon-theme: "Papirus";
    display-drun: " Apps";
    display-run: " Run";
    display-window: " Windows";
    drun-display-format: "{icon}  {name}";
    window-format: "{w} · {c}";
    hover-select: true;
    me-select-entry: "";
    me-accept-entry: "MousePrimary";
}

* {
    font: "JetBrainsMono Nerd Font 12";

    bg0: rgba(18, 22, 48, 90%);
    bg1: rgba(29, 33, 69, 95%);
    bg2: #3A3F86;

    fg0: #F3F3FF;
    fg1: #C7C9F4;
    fg2: #9DA5D9;

    accent: #67E7F7;
    accent-alt: #A6B3FF;
    border-col: #7E86D9;
    urgent: #F2A2C6;
    good: #B7F7D8;

    background-color: transparent;
    text-color: @fg0;
}

window {
    transparency: "real";
    location: center;
    anchor: center;
    fullscreen: false;

    width: 42%;
    padding: 24px;
    margin: 0px;

    border: 2px solid;
    border-radius: 22px;
    border-color: rgba(126, 134, 217, 55%);
    background-color: @bg0;
    cursor: "default";
}

mainbox {
    enabled: true;
    spacing: 18px;
    background-color: transparent;
    orientation: vertical;
    children: [ "inputbar", "listview", "mode-switcher" ];
}

inputbar {
    enabled: true;
    spacing: 12px;
    padding: 14px 16px;
    border: 0px;
    border-radius: 16px;
    background-color: @bg1;
    text-color: @fg0;
    children: [ "textbox-prompt-colon", "entry" ];
}

textbox-prompt-colon {
    enabled: true;
    expand: false;
    str: "";
    padding: 0px 6px 0px 0px;
    text-color: @accent;
    background-color: transparent;
}

entry {
    enabled: true;
    expand: true;
    placeholder: "Launch something...";
    placeholder-color: @fg2;
    background-color: transparent;
    text-color: @fg0;
    cursor: text;
}

listview {
    enabled: true;
    columns: 1;
    lines: 8;
    cycle: true;
    dynamic: true;
    fixed-height: false;
    layout: vertical;
    reverse: false;
    scrollbar: false;
    spacing: 10px;
    background-color: transparent;
    text-color: @fg0;
}

element {
    enabled: true;
    spacing: 12px;
    padding: 12px 14px;
    border: 1px solid;
    border-radius: 15px;
    border-color: transparent;
    background-color: transparent;
    text-color: @fg1;
    cursor: pointer;
}

element normal.normal {
    background-color: transparent;
    text-color: @fg1;
}

element alternate.normal {
    background-color: rgba(255, 255, 255, 3%);
    text-color: @fg1;
}

element normal.urgent {
    background-color: rgba(242, 162, 198, 10%);
    border-color: rgba(242, 162, 198, 18%);
    text-color: @fg0;
}

element normal.active {
    background-color: rgba(183, 247, 216, 8%);
    border-color: rgba(183, 247, 216, 16%);
    text-color: @fg0;
}

element selected.normal {
    background-color: rgba(103, 231, 247, 14%);
    border-color: rgba(103, 231, 247, 34%);
    text-color: @fg0;
}

element selected.active {
    background-color: rgba(183, 247, 216, 14%);
    border-color: rgba(183, 247, 216, 32%);
    text-color: @fg0;
}

element selected.urgent {
    background-color: rgba(242, 162, 198, 15%);
    border-color: rgba(242, 162, 198, 34%);
    text-color: @fg0;
}

element-icon {
    background-color: transparent;
    size: 22px;
    vertical-align: 0.5;
}

element-text {
    background-color: transparent;
    text-color: inherit;
    vertical-align: 0.5;
}

mode-switcher {
    enabled: true;
    spacing: 10px;
    background-color: transparent;
}

button {
    padding: 10px 14px;
    border: 0px;
    border-radius: 12px;
    background-color: @bg1;
    text-color: @fg2;
}

button selected {
    background-color: rgba(166, 179, 255, 16%);
    text-color: @fg0;
}
